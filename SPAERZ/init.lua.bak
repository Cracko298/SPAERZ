local spears = {}
local spearData = {} -- Cache for C++ pointers to prevent memory leaks
local enabled = true
local VELOCITY_MULT = 10.0 -- Suggested multiplier for satisfying scaling

-- Modern Minecraft Sword Stats for Tier Equivalents
local TIER_STATS = {
    wood    = { durability = 59,   enchant = 15, tierDamage = 1 },
    stone   = { durability = 131,  enchant = 5,  tierDamage = 2 },
    iron    = { durability = 250,  enchant = 14, tierDamage = 3 },
    gold    = { durability = 32,   enchant = 22, tierDamage = 4 },
    diamond = { durability = 1561, enchant = 10, tierDamage = 5 }
}

--------------------------------------------------
-- ITEM REGISTRATION
--------------------------------------------------

local function registerSpear(name, id, gameTier)
    -- Registers the item as a sword base
    local item = Game.Items.registerSwordItem(name .. "_spear", id, gameTier)
    
    if item then
        local stats = TIER_STATS[name]
        
        -- Apply Modern Sword-Equivalent Stats
        gameTier.Durability = stats.durability
        gameTier.Enchantability = stats.enchant
        
        -- Prevent mining behavior (identical to swords)
        gameTier.MiningLevel = 0
        gameTier.MiningEfficiency = 1.0 

        item.NameID = name:gsub("^%l", string.upper) .. " Spear"
        item.DescriptionID = "A " .. name .. " spear"

        -- REALTIME MANIPULATION SETUP (Optimized)
        -- Get the Lua wrapper address
        local addrString = tostring(item):match("^userdata: (.+)")
        if addrString then
            local userdataAddr = tonumber(addrString, 16)
            
            -- Dereference to get the actual C++ pointer from memory (as per your screenshot)
            local cppPointer = Core.Memory.readU32(userdataAddr)
            
            if cppPointer then
                -- Store the damage address (Pointer + 0xAC) and tier base
                spearData[item.ID] = {
                    damageAddr = cppPointer + 0xAC,
                    tierValue = stats.tierDamage
                }
            end
        end
    end
    return item
end

Game.Items.OnRegisterItems:Connect(function()
    spears.wood    = registerSpear("wood",    6000, Game.Items.ToolTiers.WOOD)
    spears.stone   = registerSpear("stone",   6001, Game.Items.ToolTiers.STONE)
    spears.iron    = registerSpear("iron",    6002, Game.Items.ToolTiers.IRON)
    spears.gold    = registerSpear("gold",    6003, Game.Items.ToolTiers.GOLD)
    spears.diamond = registerSpear("diamond", 6004, Game.Items.ToolTiers.DIAMOND)
end)

--------------------------------------------------
-- REAL-TIME VELOCITY DAMAGE (U32 VERSION)
--------------------------------------------------

Core.Graphics.OnNewFrame:Connect(function()
    if not enabled then return end

    -- Check if player is holding an item
    local held = Game.LocalPlayer.Inventory.Slots["hand"]
    if not held or held:isEmpty() then return end

    -- Fast lookup in our spear cache
    local data = spearData[held.Item.ID]
    if not data then return end 

    -- Calculate current horizontal velocity speed
    local vx, vy, vz = Game.LocalPlayer.Velocity.get()
    local speed = math.sqrt(vx * vx + vz * vz)

    -- Formula: Tier Base + (Speed * Multiplier)
    -- We use math.floor because u32 memory only accepts whole integers.
    local dynamicBonus = math.floor(data.tierValue + (speed * VELOCITY_MULT))

    -- WRITE TO MEMORY as U32 (Offset 0xAC from your screenshot)
    Core.Memory.writeU32(data.damageAddr, dynamicBonus)
end)

--------------------------------------------------
-- TEXTURES & CREATIVE
--------------------------------------------------

Game.Items.OnRegisterItemsTextures:Connect(function()
    local index = 0
    local order = {spears.wood, spears.stone, spears.iron, spears.gold, spears.diamond}
    for _, spear in ipairs(order) do
        if spear then 
            spear:setTexture(spear, "items", index) 
            index = index + 1
        end
    end
end)

Game.Items.OnRegisterCreativeItems:Connect(function()
    local pos = 0
    local order = {spears.wood, spears.stone, spears.iron, spears.gold, spears.diamond}
    for _, spear in ipairs(order) do
        if spear then 
            Game.Items.registerCreativeItem(spear, 1, pos) 
            pos = pos + 1
        end
    end
end)

--------------------------------------------------
-- RECIPES
--------------------------------------------------

Game.Recipes.OnRegisterRecipes:Connect(function(recipes)
    local materials = { 
        wood = "planks", 
        stone = "cobblestone", 
        iron = "iron_ingot", 
        gold = "gold_ingot", 
        diamond = "diamond" 
    }
    
    for tierName, spear in pairs(spears) do
        if spear then
            local matName = materials[tierName]
            local mat = Game.Items.findItemByName(matName)
            local stick = Game.Items.findItemByName("stick")
            
            if mat and stick then
                local result = Game.Items.getItemInstance(spear, 1, 0)
                Game.Recipes.registerShapedRecipe(
                    recipes, result, 0, 0, 
                    " M ", 
                    " S ", 
                    " S ", 
                    { M = mat, S = stick }
                )
            end
        end
    end
end)

--------------------------------------------------
-- MENU
--------------------------------------------------

local folder = Core.Menu.getMenuFolder()

folder:newEntry("Toggle Velocity Spears", function()
    enabled = not enabled
    Core.Menu.showMessageBox("Velocity Spears: " .. (enabled and "ON" or "OFF"))
end)

folder:newEntry("Set Velocity Multiplier", function()
    local val = Core.Keyboard.getNumber("Enter multiplier (current: " .. VELOCITY_MULT .. "):")
    if val then 
        VELOCITY_MULT = val 
        Core.Menu.showMessageBox("Multiplier set to: " .. val)
    end
end)

folder:newEntry("Give All Spears", function()
    local slot = 1
    local order = {spears.wood, spears.stone, spears.iron, spears.gold, spears.diamond}
    for _, spear in ipairs(order) do
        if spear then
            local invSlot = Game.LocalPlayer.Inventory.Slots[slot]
            if invSlot then
                invSlot:setItem(spear, 1)
                slot = slot + 1
            end
        end
    end
    Core.Menu.showMessageBox("Spears Added to hotbar!")
end)